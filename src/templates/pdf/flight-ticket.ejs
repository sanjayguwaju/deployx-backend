<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Flight Itinerary - <%= candidate.firstName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-gray-50 p-8">
    <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        
        <!-- Header -->
        <div class="bg-blue-600 px-8 py-6 flex justify-between items-center text-white">
            <div>
                <h1 class="text-2xl font-bold">E-Ticket / Itinerary</h1>
                <p class="text-blue-200 text-sm mt-1">Booking Ref: <span class="font-bold text-white"><%= ticket.pnr || 'PENDING' %></span></p>
            </div>
            <div class="text-right">
                <% if (tenant.logoUrl) { %>
                    <img src="<%= tenant.logoUrl %>" alt="Logo" class="h-10 bg-white rounded p-1 object-contain">
                <% } else { %>
                    <h2 class="text-xl font-bold"><%= tenant.name %></h2>
                <% } %>
            </div>
        </div>

        <div class="p-8">
            <!-- Passenger Info -->
            <div class="mb-8">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Passenger Information</h3>
                <div class="flex items-center gap-6">
                    <% if (candidate.photoUrl) { %>
                        <img src="<%= candidate.photoUrl %>" class="w-16 h-16 rounded-full object-cover shadow-sm">
                    <% } %>
                    <div>
                        <p class="text-xl font-bold text-gray-900"><%= candidate.firstName %> <%= candidate.lastName %></p>
                        <p class="text-gray-600">Passport: <span class="font-medium"><%= candidate.passportNumber %></span></p>
                    </div>
                </div>
            </div>

            <!-- Flight Details -->
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Flight Details</h3>
            
            <div class="border border-gray-200 rounded-xl p-6 mb-8 relative">
                
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <p class="text-sm text-gray-500">Flight</p>
                        <p class="text-lg font-bold text-gray-900"><%= ticket.flightNumber || 'TBD' %></p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500">Airline</p>
                        <p class="text-lg font-bold text-gray-900"><%= ticket.airline || 'TBD' %></p>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="text-center">
                        <p class="text-3xl font-black text-gray-900"><%= ticket.departureCity || 'KTM' %></p>
                        <p class="text-sm text-gray-500 mt-1"><%= ticket.departureTime ? new Date(ticket.departureTime).toLocaleString() : 'TBD' %></p>
                    </div>
                    
                    <div class="flex-1 px-8 relative flex items-center justify-center">
                        <div class="h-0.5 w-full bg-gray-300 border-t-2 border-dashed border-gray-300"></div>
                        <div class="absolute bg-white px-2 text-gray-400">
                            ✈️
                        </div>
                    </div>

                    <div class="text-center">
                        <p class="text-3xl font-black text-gray-900"><%= ticket.arrivalCity || 'DXB' %></p>
                        <p class="text-sm text-gray-500 mt-1"><%= ticket.arrivalTime ? new Date(ticket.arrivalTime).toLocaleString() : 'TBD' %></p>
                    </div>
                </div>
            </div>

            <!-- Employer Info -->
            <% if (employer) { %>
            <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Destination Employer</h3>
                <p class="font-bold text-gray-900"><%= employer.companyName %></p>
                <p class="text-gray-600 text-sm"><%= employer.city %>, <%= employer.country %></p>
            </div>
            <% } %>

            <!-- Footer -->
            <div class="mt-12 text-center text-xs text-gray-400 border-t border-gray-100 pt-6">
                <p>Please arrive at the airport at least 3 hours before departure.</p>
                <p class="mt-2">Generated by DeployX OS</p>
            </div>
        </div>
    </div>
</body>
</html>
