<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Employment Contract</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333; }
    .page-break { page-break-after: always; }
  </style>
</head>
<body class="bg-white p-12">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-center border-b-2 border-gray-800 pb-6 mb-8">
      <div>
        <h1 class="text-3xl font-bold uppercase tracking-wider text-gray-900">Employment Contract</h1>
        <p class="text-gray-500 mt-1">Contract ID: <%= contract._id %></p>
      </div>
      <div class="text-right">
        <% if (tenant && tenant.logoUrl) { %>
          <img src="<%= tenant.logoUrl %>" alt="Agency Logo" class="h-16 object-contain inline-block">
        <% } else { %>
          <h2 class="text-2xl font-bold text-blue-900"><%= tenant ? tenant.name : "DeployX Agency" %></h2>
        <% } %>
      </div>
    </div>

    <!-- Parties -->
    <div class="mb-8 bg-gray-50 p-6 rounded-lg">
      <h3 class="text-lg font-bold mb-4 uppercase text-gray-700">Parties to the Agreement</h3>
      <div class="grid grid-cols-2 gap-8">
        <div>
          <p class="text-sm text-gray-500 font-semibold uppercase mb-1">Employer</p>
          <% if (employer) { %>
            <p class="font-bold text-lg"><%= employer.companyName %></p>
            <p class="text-gray-700"><%= employer.industry %></p>
            <p class="text-gray-700"><%= employer.country %></p>
          <% } else { %>
            <p class="font-bold">Not Specified</p>
          <% } %>
        </div>
        <div>
          <p class="text-sm text-gray-500 font-semibold uppercase mb-1">Employee (Candidate)</p>
          <% if (candidate) { %>
            <p class="font-bold text-lg"><%= candidate.firstName %> <%= candidate.lastName %></p>
            <p class="text-gray-700">Passport: <%= candidate.passportNumber || "N/A" %></p>
            <p class="text-gray-700"><%= candidate.nationality || "Nepal" %></p>
          <% } else { %>
            <p class="font-bold">Not Specified</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Terms (Mocked for template) -->
    <div class="mb-12 prose max-w-none">
      <h3 class="text-lg font-bold uppercase text-gray-700 border-b pb-2 mb-4">Terms and Conditions</h3>
      <p>This agreement confirms the employment of the Candidate by the Employer under the following standard terms:</p>
      <ul>
        <li><strong>Position:</strong> As per Demand Allocation</li>
        <li><strong>Duration:</strong> 2 Years (Renewable)</li>
        <li><strong>Working Hours:</strong> 8 hours per day, 6 days a week</li>
        <li><strong>Accommodation & Food:</strong> Provided by Employer</li>
        <li><strong>Medical & Insurance:</strong> Provided by Employer as per local labor law</li>
      </ul>
      <p class="text-sm text-gray-600 mt-4">
        By signing this document, both parties agree to abide by the rules and regulations set forth by the Ministry of Labor and the respective destination country's labor laws.
      </p>
    </div>

    <!-- Signatures -->
    <div class="mt-16 pt-8 border-t border-gray-300">
      <h3 class="text-lg font-bold mb-8 uppercase text-gray-700">Signatures</h3>
      
      <div class="grid grid-cols-2 gap-12">
        <!-- Candidate Signature Box -->
        <div>
          <p class="text-sm font-semibold text-gray-500 uppercase mb-4">Candidate Signature</p>
          
          <% 
            let candidateSig = contract.signatures.find(s => s.signerType === 'candidate');
          %>
          
          <% if (candidateSig && candidateSig.signatureUrl) { %>
            <div class="mb-2 h-24 flex items-end">
              <img src="<%= candidateSig.signatureUrl %>" class="max-h-24 max-w-full" alt="Candidate Signature">
            </div>
            <div class="border-t border-gray-400 pt-2">
              <p class="font-bold"><%= candidate ? candidate.firstName + ' ' + candidate.lastName : 'Candidate' %></p>
              <p class="text-xs text-gray-500">Signed: <%= new Date(candidateSig.signedAt).toLocaleString() %></p>
              <p class="text-xs text-gray-400">IP: <%= candidateSig.ipAddress %></p>
            </div>
          <% } else { %>
            <div class="h-24 border-b border-gray-400 mb-2"></div>
            <p class="font-bold"><%= candidate ? candidate.firstName + ' ' + candidate.lastName : 'Candidate' %></p>
            <p class="text-xs text-gray-400 italic">Pending Signature</p>
          <% } %>
        </div>

        <!-- Employer/Agency Signature Box -->
        <div>
          <p class="text-sm font-semibold text-gray-500 uppercase mb-4">Employer / Authorized Agency</p>
          
          <% 
            let employerSig = contract.signatures.find(s => s.signerType === 'employer');
          %>
          
          <% if (employerSig && employerSig.signatureUrl) { %>
            <div class="mb-2 h-24 flex items-end">
              <img src="<%= employerSig.signatureUrl %>" class="max-h-24 max-w-full" alt="Employer Signature">
            </div>
            <div class="border-t border-gray-400 pt-2">
              <p class="font-bold"><%= employer ? employer.companyName : 'Employer' %></p>
              <p class="text-xs text-gray-500">Signed: <%= new Date(employerSig.signedAt).toLocaleString() %></p>
              <p class="text-xs text-gray-400">IP: <%= employerSig.ipAddress %></p>
            </div>
          <% } else { %>
            <div class="h-24 border-b border-gray-400 mb-2 flex items-end justify-center">
              <% if (tenant && tenant.logoUrl) { %>
                 <span class="text-gray-200 text-4xl uppercase tracking-widest font-black opacity-30 select-none">AUTHORIZED</span>
              <% } %>
            </div>
            <p class="font-bold"><%= employer ? employer.companyName : 'Authorized Signatory' %></p>
            <p class="text-xs text-gray-400 italic">Pending Signature</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-16 text-center text-xs text-gray-400 border-t pt-4">
      <p>Generated by DeployX OS &copy; <%= new Date().getFullYear() %></p>
      <p>Document Integrity Hash: <%= contract._id %></p>
    </div>
  </div>
</body>
</html>
