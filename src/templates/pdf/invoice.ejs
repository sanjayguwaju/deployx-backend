<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice <%= invoice.invoiceNumber %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333; }
        .print-break { page-break-inside: avoid; }
    </style>
</head>
<body class="bg-white p-8">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-start border-b border-gray-200 pb-8 mb-8">
            <div>
                <% if (tenant.logoUrl) { %>
                    <img src="<%= tenant.logoUrl %>" alt="Agency Logo" class="h-16 object-contain mb-4">
                <% } else { %>
                    <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= tenant.name %></h1>
                <% } %>
                <p class="text-gray-500 text-sm"><%= tenant.address || 'Global Manpower Services' %></p>
                <p class="text-gray-500 text-sm"><%= tenant.email || 'contact@agency.com' %></p>
            </div>
            <div class="text-right">
                <h2 class="text-4xl font-bold text-gray-200 uppercase tracking-wider mb-2">Invoice</h2>
                <p class="text-gray-900 font-semibold text-lg">#<%= invoice.invoiceNumber %></p>
                <p class="text-gray-500 text-sm">Date: <%= new Date(invoice.createdAt).toLocaleDateString() %></p>
                <p class="text-gray-500 text-sm">Due Date: <%= new Date(invoice.dueDate).toLocaleDateString() %></p>
                
                <div class="mt-4 inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase
                    <%= invoice.status === 'paid' ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800' %>">
                    <%= invoice.status %>
                </div>
            </div>
        </div>

        <!-- Billing Info -->
        <div class="flex justify-between mb-12">
            <div class="w-1/2">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Bill To</h3>
                <p class="text-gray-900 font-bold"><%= client.name %></p>
                <p class="text-gray-600 text-sm whitespace-pre-line"><%= client.address || 'N/A' %></p>
                <p class="text-gray-600 text-sm"><%= client.email || 'N/A' %></p>
            </div>
            <% if (candidate) { %>
            <div class="w-1/2 text-right">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Regarding Candidate</h3>
                <p class="text-gray-900 font-bold"><%= candidate.firstName %> <%= candidate.lastName %></p>
                <p class="text-gray-600 text-sm">Passport: <%= candidate.passportNumber %></p>
            </div>
            <% } %>
        </div>

        <!-- Line Items -->
        <table class="w-full text-left mb-8">
            <thead>
                <tr class="border-b border-gray-200 text-sm font-semibold text-gray-600">
                    <th class="py-3 px-2">Description</th>
                    <th class="py-3 px-2 text-right">Amount</th>
                </tr>
            </thead>
            <tbody>
                <% invoice.items.forEach(function(item) { %>
                <tr class="border-b border-gray-100 print-break">
                    <td class="py-4 px-2 text-gray-800"><%= item.description %></td>
                    <td class="py-4 px-2 text-right text-gray-900"><%= invoice.currency %> <%= item.amount.toFixed(2) %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Totals -->
        <div class="flex justify-end mb-16">
            <div class="w-1/3">
                <div class="flex justify-between py-2 text-sm text-gray-600">
                    <span>Subtotal</span>
                    <span><%= invoice.currency %> <%= invoice.totalAmount.toFixed(2) %></span>
                </div>
                <div class="flex justify-between py-2 border-t border-gray-200 font-bold text-lg text-gray-900 mt-2">
                    <span>Total</span>
                    <span><%= invoice.currency %> <%= invoice.totalAmount.toFixed(2) %></span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center text-sm text-gray-400 border-t border-gray-200 pt-8">
            <p>Thank you for your business.</p>
            <p>If you have any questions about this invoice, please contact <%= tenant.email || 'support@agency.com' %></p>
            <p class="mt-4 text-xs">Generated securely via DeployX OS</p>
        </div>
    </div>
</body>
</html>
