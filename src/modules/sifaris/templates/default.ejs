<!DOCTYPE html>
<html lang="ne">
<head>
  <meta charset="UTF-8">
  <title>सिफारिस</title>
  <style>
    body {
      font-family: 'Kalimati', 'Mangal', 'Arial Unicode MS', sans-serif;
      margin: 0;
      padding: 0;
      color: #333;
    }
    .header {
      text-align: center;
      border-bottom: 2px solid #b30000;
      padding-bottom: 15px;
      margin-bottom: 20px;
    }
    .header h1 {
      margin: 5px 0;
      color: #b30000;
      font-size: 24px;
    }
    .header h2 {
      margin: 5px 0;
      font-size: 18px;
    }
    .header h3 {
      margin: 5px 0;
      font-size: 16px;
      font-weight: normal;
    }
    .meta-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 30px;
      font-size: 14px;
    }
    .content {
      line-height: 1.8;
      font-size: 15px;
      text-align: justify;
    }
    .title {
      text-align: center;
      font-size: 20px;
      font-weight: bold;
      text-decoration: underline;
      margin: 20px 0;
    }
    .footer {
      margin-top: 50px;
      text-align: right;
    }
    .signature {
      display: inline-block;
      text-align: center;
    }
    .signature-line {
      border-bottom: 1px dotted #333;
      width: 150px;
      margin-bottom: 5px;
      display: inline-block;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1><%= municipalityNameNp %></h1>
    <h2>नगर कार्यपालिकाको कार्यालय</h2>
    <h3>वडा नं. <%= ward %></h3>
    <h3>कर्णाली प्रदेश, नेपाल</h3>
  </div>

  <div class="meta-info">
    <div>प.सं.: <%= data.patraSankhya || '...........' %></div>
    <div>मिति: <%= data.miti || date %></div>
  </div>
  <div class="meta-info">
    <div>च.नं.: <%= data.chalaniNo || '...........' %></div>
  </div>

  <div class="title">
    विषय: <%= data.subject || 'सिफारिस सम्बन्धमा' %>
  </div>

  <div class="content">
    <p>
      <%= data.content || 'प्रस्तुत विषयमा, यस नगरपालिका वडा नं. ' + ward + ' निवासी श्री/श्रीमती ' + (data.applicantName || '...........') + ' ले यस कार्यालयमा दिनुभएको निवेदन अनुसार उहाँको ' + (data.reason || '...........') + ' को लागि यो सिफारिस प्रदान गरिएको छ।' %>
    </p>
    <p>
      उहाँको बारेमा थप जानकारी आवश्यक परेमा यस कार्यालयमा सम्पर्क गर्न सक्नुहुनेछ।
    </p>
  </div>

  <div class="footer" style="display: flex; justify-content: space-between; align-items: flex-end;">
    <div class="qr-code" style="text-align: center;">
      <% if (locals.qrCode) { %>
        <img src="<%= qrCode %>" alt="Verification QR Code" style="width: 100px; height: 100px;" />
        <div style="font-size: 10px; color: #666; margin-top: 4px;">स्क्यान गरी प्रमाणीकरण गर्नुहोस्</div>
        <div style="font-size: 8px; color: #888;"><%= verificationHash %></div>
      <% } %>
    </div>
    <div class="signature">
      <div class="signature-line"></div>
      <br>
      <strong>वडा अध्यक्ष / वडा सचिव</strong>
    </div>
  </div>
</body>
</html>
