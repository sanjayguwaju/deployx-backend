{
  "name": "deployx-backend",
  "version": "1.0.0",
  "description": "DeployX — Express + Mongoose + CASL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "swagger": "ts-node swagger.ts",
    "seed": "ts-node src/utils/seed-deployx.ts",
    "seed:clear": "ts-node src/utils/seed-deployx.ts --clear",
    "lint": "eslint src --ext .ts",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@casl/ability": "^6.7.1",
    "@scalar/express-api-reference": "^0.10.7",
    "@ucast/core": "^1.10.2",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^6.0.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.13",
    "puppeteer": "^25.3.0",
