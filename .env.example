# Server
NODE_ENV=development
PORT=8081

# MongoDB
MONGODB_URI=mongodb://localhost:27017/palata_mms

# JWT & Security
JWT_SECRET=change-me-super-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
MASTER_PASSWORD=

# Redis
# Option 1: Use a hosted Redis URL (e.g. Redis Enterprise Cloud, Upstash, AWS ElastiCache)
# REDIS_URL=redis://default:t5ZCqSD9M2JdREEpSj0HPVvalbsCj6PB@petal-low-teaching-43125.db.redis.io:19301
# Option 2: Use host and port (fallback if REDIS_URL is not set)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS (Sparrow SMS – Nepal)
SMS_API_URL=https://api.sparrowsms.com/v2/sms/
SMS_TOKEN=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload
MAX_FILE_SIZE_MB=10

# S3 / Cloudflare R2 / DigitalOcean Spaces Storage
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET_NAME=palata-mms-bucket
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://pub-<your_id>.r2.dev

# eSewa Payment Gateway
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET=8gBm/:&EnhH.1/q
